<%- include('partials/header', { pageTitle: 'Turneringer', currentUser }) %>
<section class="card">
  <h1>Turneringer</h1>
  <%- include('partials/messages', { error, success }) %>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <form action="/tournaments" method="post" class="form-grid" style="margin-bottom: 16px;">
      <label>
        Navn
        <input name="name" type="text" required>
      </label>
      <label>
        Dato
        <input name="date" type="date" required>
      </label>
      <button type="submit">Opprett turnering</button>
    </form>
  <% } %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Navn</th>
          <th>Dato</th>
          <th>Handlinger</th>
        </tr>
      </thead>
      <tbody>
        <% tournaments.forEach((tournament) => { %>
          <% const dateValue = new Date(tournament.date).toISOString().slice(0, 10); %>
          <tr>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                <input form="tournament-form-<%= tournament.id %>" name="name" type="text" value="<%= tournament.name %>" required>
              <% } else { %>
                <%= tournament.name %>
              <% } %>
            </td>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                  <input form="tournament-form-<%= tournament.id %>" name="date" type="date" value="<%= dateValue %>" required>
              <% } else { %>
                <%= dateValue %>
              <% } %>
            </td>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                  <form id="tournament-form-<%= tournament.id %>" action="/tournaments/<%= tournament.id %>/update" method="post"></form>
                  <button type="submit" form="tournament-form-<%= tournament.id %>">Lagre</button>
                <form action="/tournaments/<%= tournament.id %>/delete" method="post" style="display:inline;">
                  <button type="submit" class="secondary">Slett</button>
                </form>
              <% } else { %>
                -
              <% } %>
            </td>
          </tr>
        <% }) %>
        <% if (!tournaments.length) { %>
          <tr><td colspan="3">Ingen turneringer registrert ennå.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials/footer') %>
