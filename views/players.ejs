<%- include('partials/header', { pageTitle: 'Spillere', currentUser }) %>
<section class="card">
  <h1>Spillere</h1>
  <%- include('partials/messages', { error, success }) %>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <form action="/players" method="post" class="form-grid" style="margin-bottom: 16px;">
      <label>
        Navn
        <input name="name" type="text" required>
      </label>
      <label>
        Alder
        <input name="age" type="number" min="1" required>
      </label>
      <label>
        Lag
        <select name="teamId" required>
          <option value="">Velg lag</option>
          <% teams.forEach((team) => { %>
            <option value="<%= team.id %>"><%= team.name %></option>
          <% }) %>
        </select>
      </label>
      <button type="submit">Opprett spiller</button>
    </form>
  <% } %>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Navn</th>
          <th>Alder</th>
          <th>Lag</th>
          <th>Handlinger</th>
        </tr>
      </thead>
      <tbody>
        <% players.forEach((player) => { %>
          <tr>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                <input form="player-form-<%= player.id %>" name="name" type="text" value="<%= player.name %>" required>
              <% } else { %>
                <%= player.name %>
              <% } %>
            </td>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                  <input form="player-form-<%= player.id %>" name="age" type="number" min="1" value="<%= player.age %>" required>
              <% } else { %>
                <%= player.age %>
              <% } %>
            </td>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                  <select form="player-form-<%= player.id %>" name="teamId" required>
                    <% teams.forEach((team) => { %>
                      <option value="<%= team.id %>" <%= String(player.team_id) === String(team.id) ? 'selected' : '' %>><%= team.name %></option>
                    <% }) %>
                  </select>
              <% } else { %>
                <%= player.team_name || '-' %>
              <% } %>
            </td>
            <td>
              <% if (currentUser && currentUser.role === 'admin') { %>
                  <form id="player-form-<%= player.id %>" action="/players/<%= player.id %>/update" method="post"></form>
                  <button type="submit" form="player-form-<%= player.id %>">Lagre</button>
                <form action="/players/<%= player.id %>/delete" method="post" style="display:inline;">
                  <button type="submit" class="secondary">Slett</button>
                </form>
              <% } else { %>
                -
              <% } %>
            </td>
          </tr>
        <% }) %>
        <% if (!players.length) { %>
          <tr><td colspan="4">Ingen spillere registrert ennå.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>
<%- include('partials/footer') %>
