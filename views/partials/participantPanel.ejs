<section id="participantPanel" class="card hidden">
  <h2>Deltakerpanel</h2>
  <form id="participantJoinForm" class="panel-box inline-form">
    <h3>Meld deg på via lag</h3>
    <label>Lag
      <select name="teamId" id="participantTeamSelect" required></select>
    </label>
    <label>Alder
      <input name="age" type="number" min="1" placeholder="Valgfritt" />
    </label>
    <button type="submit">Meld meg på</button>
  </form>
</section>
