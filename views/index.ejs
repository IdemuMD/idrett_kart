<%- include('partials/header', { pageTitle, currentUser }) %>

<section class="card hero">
  <p class="eyebrow">Turneringssystem</p>
  <% if (currentUser && currentUser.role === 'admin') { %>
    <h1>Administrer turneringer, lag, spillere og kamper</h1>
    <p class="muted">Bruk EJS-sidene til å opprette og oppdatere data direkte i MongoDB.</p>
  <% } else { %>
    <h1>Se kampoppsett og resultater</h1>
    <p class="muted">Du kan se kampene her. Logg inn for å få tilgang til flere funksjoner.</p>
  <% } %>
  <% if (currentUser) { %>
    <div class="hero-status">
      <span>Du er logget inn som <strong><%= currentUser.name %></strong> (<%= currentUser.role %>).</span>
      <form action="/logout" method="post">
        <button type="submit" class="secondary">Logg ut</button>
      </form>
    </div>
  <% } else { %>
    <div style="display:flex; gap:10px; flex-wrap:wrap; margin-top:14px;">
      <a class="hero-link" href="/login">Logg inn</a>
      <a class="hero-link secondary-link" href="/matches">Se kamper</a>
    </div>
  <% } %>
</section>

<%- include('partials/messages', { error, success }) %>

<section class="card">
  <h2>Rask oversikt</h2>
  <div class="tournament-cards">
    <% if (currentUser && currentUser.role === 'admin') { %>
      <article class="tournament-card">
        <p class="name">Turneringer</p>
        <p><%= tournaments.length %> registrert(e)</p>
      </article>
      <article class="tournament-card">
        <p class="name">Lag</p>
        <p><%= teams.length %> registrert(e)</p>
      </article>
    <% } %>
    <article class="tournament-card">
      <p class="name">Kamper</p>
      <p><%= matches.length %> registrert(e)</p>
    </article>
  </div>
</section>

<% if (currentUser && currentUser.role === 'admin') { %>
  <section class="card">
    <h2>Siste turneringer</h2>
    <div class="table-wrap">
      <table>
        <thead>
          <tr>
            <th>Navn</th>
            <th>Dato</th>
          </tr>
        </thead>
        <tbody>
          <% tournaments.slice(0, 5).forEach((tournament) => { %>
            <tr>
              <td><%= tournament.name %></td>
              <td><%= new Date(tournament.date).toLocaleDateString('nb-NO') %></td>
            </tr>
          <% }) %>
          <% if (!tournaments.length) { %>
            <tr><td colspan="2">Ingen turneringer registrert ennå.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>
<% } %>

<section class="card">
  <h2>Siste kamper</h2>
  <div class="table-wrap">
    <table>
      <thead>
        <tr>
          <th>Lag 1</th>
          <th>Lag 2</th>
          <th>Tid</th>
          <th>Resultat</th>
        </tr>
      </thead>
      <tbody>
        <% matches.slice(0, 5).forEach((match) => { %>
          <tr>
            <td><%= match.team1_name || '-' %></td>
            <td><%= match.team2_name || '-' %></td>
            <td><%= new Date(match.time).toLocaleString('nb-NO') %></td>
            <td><%= match.result || 'Ikke registrert' %></td>
          </tr>
        <% }) %>
        <% if (!matches.length) { %>
          <tr><td colspan="4">Ingen kamper registrert ennå.</td></tr>
        <% } %>
      </tbody>
    </table>
  </div>
</section>

<%- include('partials/footer') %>
